# Copy to .env and fill only values belonging to your authorized account.
# Capture token/userid from a successful request to usergw.magicangle.cn or
# userapi.magicangle.cn. Never commit the resulting .env file.
MAGICANGLE_USER_ID=
MAGICANGLE_TOKEN=
MAGICANGLE_STORE_ID=

# Optional browser client metadata expected by the upstream service.
MAGICANGLE_CHANNEL_NO=web
MAGICANGLE_APP_VERSION=1.0.0-web
MAGICANGLE_CLIENT_TYPE=web
MAGICANGLE_ORIGIN=https://hfive.cfgsdok.com
MAGICANGLE_REFERER=https://hfive.cfgsdok.com/
# Leave empty to use the built-in mobile Safari User-Agent, or paste the exact
# User-Agent from Charles when the upstream service requires it.
MAGICANGLE_USER_AGENT=
UPSTREAM_TIMEOUT_SECONDS=15

# Comma-separated origins allowed to call this local API.
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:8081,http://localhost:8081
