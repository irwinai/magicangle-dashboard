# Copy to .env and fill only values belonging to your authorized account.
MAGICANGLE_USER_ID=
MAGICANGLE_TOKEN=
MAGICANGLE_STORE_ID=ds711

# Optional browser client metadata expected by the upstream service.
MAGICANGLE_CHANNEL_NO=web
MAGICANGLE_APP_VERSION=1.0.0-web
MAGICANGLE_CLIENT_TYPE=web

# Comma-separated origins allowed to call this local API.
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:8081,http://localhost:8081
